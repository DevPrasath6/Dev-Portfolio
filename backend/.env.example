# Server
PORT=5000

# MongoDB
# Use your own MongoDB Atlas/local connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/Portfolio?retryWrites=true&w=majority

# JWT
# Generate a long random secret for production
JWT_SECRET=replace_with_a_long_random_secret

# Frontend URL (for CORS)
# Local frontend (Vite default): http://localhost:5173
# Production frontend: your deployed frontend URL (example: https://your-frontend.onrender.com)
CLIENT_URL=http://localhost:5173
